# Supabase (obrigatório)
# URL do projeto: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Chave service_role — APENAS no servidor (Render secrets / .env local, nunca no front-end)
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Webhook n8n — fluxo "controle_metragem"
# Production URL (n8n Cloud):
# https://almoxestrategic.app.n8n.cloud/webhook/d408b389-4567-4b3f-83eb-afa9ffe0d919
N8N_WEBHOOK_URL=
# Fallback opcional no client (somente se o webhook for público):
VITE_N8N_WEBHOOK_URL=

# Segredo usado uma única vez para criar o admin inicial (npm run setup:admin)
ADMIN_SETUP_SECRET=estrategic-setup-2026

# Render / produção
PORT=3000
NODE_ENV=production
