# Supabase (obrigatório — Dashboard → Settings → API)
VITE_SUPABASE_URL=https://lanllzwoylgedegkawsa.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Chave service_role — APENAS no servidor (Render secrets / .env local)
# Nunca exponha no front-end. Usada por cadastro/alterar senha e setup:admin.
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Segredo para criar admin inicial (npm run setup:admin)
ADMIN_SETUP_SECRET=estrategic-setup-2026
ADMIN_EMAIL=admin@estrategic.com
ADMIN_PASSWORD=Estrategic@2026!
ADMIN_NAME=Administrador Estrategic

# Render / produção
PORT=3000
NODE_ENV=development

# ── E-mail SAP (Resend) — configure APENAS nos Secrets do Supabase ──
# RESEND_API_KEY, RESEND_FROM_EMAIL, RESEND_TO_EMAIL, EVIDENCIA_WEBHOOK_SECRET
